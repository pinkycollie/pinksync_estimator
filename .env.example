# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file with real credentials

# Database Configuration (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/pinksync_db

 ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pinkyai:[password]@localhost:5432/pinkyai
POSTGRES_DB=pinkyai
POSTGRES_USER=pinkyai
POSTGRES_PASSWORD=[password]

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
SESSION_SECRET=change_me_to_32_random_chars_min

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SHEETS_ID=

# ── supabase ────────────────────────────────────────────────────────────────────
supabase

# ── pgAdmin
────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@mbtq.dev
PGADMIN_PASSWORD=admin

# External Module Connectors
# PinkFlow TestContainer - Test validation and approval workflows
PINKFLOW_API_URL=https://pinkflow.mbtq.dev
PINKFLOW_API_KEY=your_pinkflow_api_key_here

# PinkSync - DeafAuth and synchronization services
PINKSYNC_API_URL=https://sync.mbtq.dev
PINKSYNC_API_KEY=your_pinksync_api_key_here

# FibonRose - Fibonacci-based estimation engine
FIBONROSE_API_URL=https://trust.mbtq.dev
FIBONROSE_API_KEY=your_fibonrose_api_key_here

# NegraRosa - Additional module (if applicable)
NEGRAROSA_API_URL=https://negrarosa.mbtq.dev
NEGRAROSA_API_KEY=your_negrarosa_api_key_here

# Deaf Community Accessibility Features
ENABLE_DEAF_AUTH=true
ENABLE_SIGN_LANGUAGE_SUPPORT=true
ENABLE_VISUAL_CUES=true

